@{
    ViewBag.Title = "Catálogo de Productos";
}

<h2 class="mb-4">Catálogo de Productos</h2>

<div class="row mb-3">
    <div class="col-md-4">
        <label>Categoría</label>
        <select id="categoria" class="form-control">
            <option value="">Todas</option>
            <option value="Futbol">Fútbol</option>
            <option value="Basquetbol">Básquetbol</option>
            <option value="Natacion">Natación</option>
            <option value="Tenis">Tenis</option>
        </select>
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button onclick="cargarProductos()" class="btn btn-primary w-100">
            Buscar
        </button>
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button onclick="confirmarPedido()" class="btn btn-success w-100">
            Confirmar Pedido
        </button>
    </div>
</div>

<table class="table table-bordered table-striped" id="tablaProductos">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoría</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<hr />

<h4>🛒 Carrito</h4>
<ul id="listaCarrito" class="list-group mb-3"></ul>

<script src="~/Scripts/jquery-3.7.0.min.js"></script>

<script>
    let carrito = [];

    function cargarProductos() {

        let categoria = $("#categoria").val();
        let url = "https://localhost:44300/api/productos";

        // ✅ Solo agrega parámetro si hay filtro
        if (categoria) {
            url += "?categoria=" + encodeURIComponent(categoria);
        }

        $.ajax({
            url: url,
            type: "GET",
            success: function (res) {

                let filas = "";

                res.Data.forEach(p => {
                    filas += `
                    <tr>
                        <td>${p.Nombre}</td>
                        <td>$${p.Precio}</td>
                        <td>${p.Stock}</td>
                        <td>${p.Categoria}</td>
                        <td>
                            <button class="btn btn-success btn-sm"
                                onclick="agregarCarrito(${p.Id}, '${p.Nombre}')">
                                Agregar
                            </button>
                        </td>
                    </tr>`;
                });

                $("#tablaProductos tbody").html(filas);
            },
            error: function (err) {
                console.error(err);
                alert("❌ Error al cargar productos");
            }
        });
    }

    function agregarCarrito(id, nombre) {
        carrito.push({ IdProducto: id, Cantidad: 1 });

        $("#listaCarrito").append(`
            <li class="list-group-item">
                ${nombre} (x1)
            </li>
        `);
    }

    function confirmarPedido() {

        if (carrito.length === 0) {
            alert("⚠️ El carrito está vacío");
            return;
        }

        let pedido = {
            Productos: carrito
        };

        console.log("Enviando:", JSON.stringify(pedido)); // DEBUG

        $.ajax({
            url: "https://localhost:44300/api/pedidos",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(pedido),

            success: function (res) {
                alert("Pedido realizado correctamente");

                carrito = [];
                $("#listaCarrito").html("");
            },

            error: function (xhr) {
                console.error(xhr.responseText);
                alert("Error: " + xhr.responseText);
            }
        });
    }

    $(document).ready(function () {
        cargarProductos();
    });
</script>